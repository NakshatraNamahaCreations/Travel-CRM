# Server
PORT=5000
NODE_ENV=development

# MongoDB — paste your Atlas URI, or use a local mongod
# Atlas example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/travel_crm
MONGODB_URI=mongodb://127.0.0.1:27017/travel_crm

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES=7d

# CORS — the client origin
CLIENT_URL=http://localhost:5173

# PDF rendering — path to a Chrome/Edge executable (auto-detected if blank)
CHROME_PATH=

# Email (SMTP) for "Email to Guest" — leave blank to keep email disabled
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=Andaman TravelCare <no-reply@andamantravelcare.com>
